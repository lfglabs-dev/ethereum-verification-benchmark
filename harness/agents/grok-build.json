{
  "schema_version": 1,
  "agent_id": "grok-build",
  "adapter": "shell",
  "track": "group/grok-build",
  "command": [
    "grok",
    "--model", "grok-build",
    "--cwd", "{workspace}",
    "--sandbox", "strict",
    "--disable-web-search",
    "--no-memory",
    "--no-subagents",
    "--always-approve",
    "--output-format", "json",
    "--max-turns", "{max_turns}",
    "--prompt-file", "{prompt_file}"
  ],
  "host_auth": {
    "env_flag": "VERITY_ALLOW_HOST_GROK_AUTH",
    "source": "~/.grok/auth.json",
    "dest": ".grok/auth.json",
    "fallback_env": "GROK_CODE_XAI_API_KEY"
  },
  "usage_pattern": "\"total_tokens\"\\s*:\\s*(\\d+)",
  "version_command": ["grok", "--version"]
}
