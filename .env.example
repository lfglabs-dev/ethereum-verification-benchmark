# Default Lean-tools harness.
# Any OpenAI-compatible chat-completions provider can be used here.
DEFAULT_HARNESS_BASE_URL=https://spark-de79.gazella-vector.ts.net/v1
DEFAULT_HARNESS_MODEL=qwen3.5-397b
DEFAULT_HARNESS_API_KEY=

# Optional tuning for the default harness.
# DEFAULT_HARNESS_MAX_FILE_CHARS=6000
# DEFAULT_HARNESS_PROMPT_CONTEXT_CHARS=8000
# DEFAULT_HARNESS_LEAN_CHECK_TIMEOUT_SECONDS=60
# DEFAULT_HARNESS_REQUEST_TIMEOUT_SECONDS=180
# DEFAULT_HARNESS_MAX_TOOL_CALLS=24

# Grok Build harness.
# Prefer this in CI or other non-interactive environments.
GROK_CODE_XAI_API_KEY=

# Local-only option: allow the Grok runner to copy ~/.grok/auth.json
# into the temporary run home. Do not use this in CI.
VERITY_ALLOW_HOST_GROK_AUTH=0
