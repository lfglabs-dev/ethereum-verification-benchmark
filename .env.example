# Default Lean-tools harness.
# Any OpenAI-compatible chat-completions provider can be used here.
# Optional profile switch. When set to qwen or glm, provider-specific
# DEFAULT_HARNESS_<PROVIDER>_* values take precedence over the generic values.
# DEFAULT_HARNESS_PROVIDER=qwen
DEFAULT_HARNESS_BASE_URL=https://spark-de79.gazella-vector.ts.net/v1
DEFAULT_HARNESS_MODEL=qwen3.5-397b
DEFAULT_HARNESS_API_KEY=

# Provider profiles for quick local switching.
DEFAULT_HARNESS_QWEN_BASE_URL=https://spark-de79.gazella-vector.ts.net/v1
DEFAULT_HARNESS_QWEN_MODEL=qwen3.5-397b
DEFAULT_HARNESS_QWEN_API_KEY=
DEFAULT_HARNESS_GLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
DEFAULT_HARNESS_GLM_MODEL=glm-5.1
DEFAULT_HARNESS_GLM_API_KEY=

# Optional tuning for the default harness.
# DEFAULT_HARNESS_MAX_FILE_CHARS=6000
# DEFAULT_HARNESS_PROMPT_CONTEXT_CHARS=8000
# DEFAULT_HARNESS_LEAN_CHECK_TIMEOUT_SECONDS=60
# DEFAULT_HARNESS_REQUEST_TIMEOUT_SECONDS=180
# DEFAULT_HARNESS_REQUEST_RETRIES=2
# DEFAULT_HARNESS_REQUEST_RETRY_BACKOFF_SECONDS=2
# DEFAULT_HARNESS_MAX_TOOL_CALLS=24
# DEFAULT_HARNESS_MAX_RESPONSE_TOKENS=4096
# DEFAULT_HARNESS_NATIVE_TOOLS=1
# DEFAULT_HARNESS_TOOL_RESULT_CHARS=6000
# DEFAULT_HARNESS_TASK_SUMMARY_CHARS=8000
# DEFAULT_HARNESS_MAX_NON_PROOF_TOOL_CALLS=8
# DEFAULT_HARNESS_ALLOW_GRINDSET_TOOLS=0
# Optional provider-specific context-window hint. Leave unset for strict OpenAI-compatible APIs.
# DEFAULT_HARNESS_CONTEXT_TOKENS=32768

# Optional initial Grok briefing check timeout.
# VERITY_INITIAL_CHECK_TIMEOUT_SECONDS=180

# Grok Build harness.
# Prefer this in CI or other non-interactive environments.
GROK_CODE_XAI_API_KEY=

# Local-only option: allow the Grok runner to copy ~/.grok/auth.json
# into the temporary run home. Do not use this in CI.
VERITY_ALLOW_HOST_GROK_AUTH=0
